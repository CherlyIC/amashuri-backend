generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SCHOOL_ADMIN
  ADMIN
}

enum SchoolType {
  PUBLIC
  PRIVATE
  GOVERNMENT_AIDED
}

enum GenderPolicy {
  COED
  BOYS_ONLY
  GIRLS_ONLY
}

enum StudentType {
  BOARDING
  DAY
}

enum EnquiryStatus {
  SENT
  READ
  REPLIED
}

enum SchoolStatus {
  DRAFT
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  reviews      Review[]
  favourites   Favourite[]
  enquiries    Enquiry[]
  comparisons  Comparison[]
  schoolAdmin  SchoolAdmin?
}

model School {
  id           String         @id @default(uuid())
  name         String
  district     String
  province     String
  schoolType   SchoolType
  genderPolicy GenderPolicy
  boarding     Boolean      @default(false)
  email        String?
  phone        String?
  latitude     Float?
  longitude    Float?
  logoUrl      String?
  description  String?
  yearEstablished Int?
  totalStudents   Int?
  status       SchoolStatus @default(DRAFT)
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())

  fees         Fee[]
  combinations Combination[]
  resources    SchoolResource?
  reviews      Review[]
  favourites   Favourite[]
  enquiries    Enquiry[]
  schoolAdmin  SchoolAdmin?
}

model Fee {
  id           String         @id @default(uuid())
  schoolId     String
  level        String
  studentType  StudentType
  amount       Float
  academicYear String

  school       School      @relation(fields: [schoolId], references: [id])
}

model Combination {
  id       String    @id @default(uuid())
  schoolId String  
  name     String
  subjects String

  school   School @relation(fields: [schoolId], references: [id])
}

model SchoolResource {
  id           String      @id @default(uuid())
  schoolId     String  @unique
  laboratory   Boolean @default(false)
  library      Boolean @default(false)
  computerRoom Boolean @default(false)
  sportsField  Boolean @default(false)
  boardingHouse Boolean @default(false)
  chapel       Boolean @default(false)

  school       School  @relation(fields: [schoolId], references: [id])
}

model Review {
  id               String      @id @default(uuid())
  schoolId         String
  userId           String
  teachingRating   Int
  facilitiesRating Int
  adminRating      Int
  overallRating    Int
  comment          String?
  createdAt        DateTime @default(now())

  school           School   @relation(fields: [schoolId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
}

model Favourite {
  id       String      @id @default(uuid())
  userId   String
  schoolId String
  savedAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  school   School   @relation(fields: [schoolId], references: [id])
}

model Enquiry {
  id          String           @id @default(uuid())
  userId      String
  schoolId    String
  message     String
  senderEmail String
  sentAt      DateTime      @default(now())
  status      EnquiryStatus @default(SENT)

  user        User          @relation(fields: [userId], references: [id])
  school      School        @relation(fields: [schoolId], references: [id])
}

model Comparison {
  id        String      @id @default(uuid())
  userId    String
  schoolIds Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model SchoolAdmin {
  id         String      @id @default(uuid())
  userId     String      @unique
  schoolId   String      @unique
  assignedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  school     School   @relation(fields: [schoolId], references: [id])
}