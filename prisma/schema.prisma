generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SCHOOL_ADMIN
  ADMIN
}

enum SchoolType {
  PUBLIC
  PRIVATE
  GOVERNMENT_AIDED
}

enum GenderPolicy {
  COED
  BOYS_ONLY
  GIRLS_ONLY
}

enum StudentType {
  BOARDING
  DAY
}

enum EnquiryStatus {
  SENT
  READ
  REPLIED
}

enum SchoolStatus {
  DRAFT
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id               String      @id @default(uuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             Role     @default(USER)
  createdAt        DateTime @default(now())
  resetToken       String?  @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  tokenVersion     Int      @default(0) @map("token_version")
  totpEnabled      Boolean  @default(false) @map("totp_enabled")
  otpHash          String?  @map("otp_hash")
  otpExpiry        DateTime? @map("otp_expiry")

  reviews       Review[]
  favourites    Favourite[]
  comparisons   Comparison[]
  enquiries     Enquiry[]
  schoolAdmin   SchoolAdmin?
  chatSessions  ChatSession[]
  notifications Notification[]
}

model School {
  id           String         @id @default(uuid())
  name         String
  district     String
  province     String
  schoolType   SchoolType
  genderPolicy GenderPolicy
  boarding     Boolean      @default(false)
  email        String?
  phone        String?
  latitude     Float?
  longitude    Float?
  logoUrl      String?
  description  String?
  yearEstablished Int?
  totalStudents   Int?
  status       SchoolStatus @default(DRAFT)
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())

  fees         Fee[]
  combinations Combination[]
  resources    SchoolResource?
  reviews      Review[]
  favourites   Favourite[]
  enquiries    Enquiry[]
  schoolAdmin  SchoolAdmin?
}

model Fee {
  id           String         @id @default(uuid())
  schoolId     String
  level        String
  studentType  StudentType
  amount       Float
  academicYear String

  school       School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Combination {
  id       String    @id @default(uuid())
  schoolId String
  name     String
  subjects String

  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model SchoolResource {
  id           String      @id @default(uuid())
  schoolId     String  @unique
  laboratory   Boolean @default(false)
  library      Boolean @default(false)
  computerRoom Boolean @default(false)
  sportsField  Boolean @default(false)
  boardingHouse Boolean @default(false)
  chapel       Boolean @default(false)

  school       School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Review {
  id               String      @id @default(uuid())
  schoolId         String
  userId           String
  teachingRating   Int
  facilitiesRating Int
  adminRating      Int
  overallRating    Int
  comment          String?
  createdAt        DateTime @default(now())

  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
  @@index([schoolId])
}

model Favourite {
  id       String      @id @default(uuid())
  userId   String
  schoolId String
  savedAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
  @@index([userId])
}

model Enquiry {
  id             String           @id @default(uuid())
  userId         String
  schoolId       String
  message        String
  senderEmail    String
  sentAt         DateTime      @default(now())
  status         EnquiryStatus @default(SENT)
  attachmentUrl  String?
  replyMessage   String?
  repliedAt      DateTime?

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId])
}

model Comparison {
  id        String      @id @default(uuid())
  userId    String
  schoolIds Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SchoolAdmin {
  id         String      @id @default(uuid())
  userId     String      @unique
  schoolId   String      @unique
  assignedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  schools   Json?
  createdAt DateTime    @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}